<?xml version="1.0" encoding="utf-8"?>
<!--
  Fody weaver configuration. Costura embeds every Copy-Local reference
  as a compressed resource in the output .exe.

  Defaults are mostly what we want; documented inline for the rest:

  - <CreateTemporaryAssemblies>: false (default). Loads embedded DLLs
    directly into memory; no temp files on disk.
  - <IncludeDebugSymbols>: true (default). Embeds .pdb where present so
    stack traces from third-party assemblies stay readable.
  - <DisableCompression>: false (default). Brotli/Deflate the resources.
  - <DisableCleanup>: false (default). Removes original Copy-Local DLLs
    from bin\Release\ after embedding so the output dir contains just
    the .exe, .exe.config, and (in Debug) .pdb.

  If a particular DLL ever needs to be excluded from embedding (e.g. a
  native interop file that can't be loaded from a resource), add it via
  <ExcludeAssemblies>:
    <ExcludeAssemblies>SomeNativeInterop</ExcludeAssemblies>
  Names are without the .dll extension; one per line.
-->
<Weavers xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <Costura />
</Weavers>
